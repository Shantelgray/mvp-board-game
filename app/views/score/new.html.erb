<h1>Score</h1>

<%= form_with(model: [@game, @score]) do |f| %>
  <% if @score.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@score.errors.count, "error") %> prevented this score from being saved:</h2>
      <ul>
        <% @score.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :points, "Points" %>
    <%= f.number_field :points %>
  </div>

  <div>
    <%= f.label :round_number, "Round Number"%>
    <%= f.number_field :round_number %>
  </div>

  <div>
    <%= f.submit "Submit Score"%>
  </div>
<% end %>
