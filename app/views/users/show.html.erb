<h1><%= @user.name %>'s Profile</h1>
<p><strong>Email:</strong> <%= @user.email %></p>

<h2>Scores:</h2>
<% @user.scores.each do |score| %>
  <p>
    <strong>Game:</strong> <%= link_to score.game.name, game_path(score.game) %> |
    <strong>Points:</strong> <%= score.points %> |
    <strong>Round:</strong> <%= score.round_number %>
  </p>
<% end %>

<%= link_to "Back to All Users", users_path %>
